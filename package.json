{
  "name": "kstyled",
  "version": "0.0.0",
  "private": true,
  "description": "Compile-time CSS-in-JS for React Native with a small, predictable runtime",
  "keywords": [
    "react-native",
    "styled-components",
    "stylesheet",
    "performance",
    "compile-time",
    "babel-plugin"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/crossplatformkorea/kstyled.git"
  },
  "license": "MIT",
  "author": "hyodotdev (https://hyo.dev)",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --filter=example",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "clean": "turbo run clean && rm -rf node_modules .turbo",
    "bun:install": "bun install",
    "kstyled:copy": "cd packages/babel-plugin-kstyled && pnpm build && cp -r dist/* /Users/hyo/Github/crossplatformkorea/cpk-ui/node_modules/babel-plugin-kstyled/dist/ && cd ../kstyled && pnpm build && cp -r dist/* /Users/hyo/Github/crossplatformkorea/cpk-ui/node_modules/kstyled/dist/ && echo '✅ kstyled packages copied to cpk-ui! Restart Metro/Storybook to apply changes.'",
    "bun:build": "bun run build",
    "bun:dev": "bun run dev",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "check": "pnpm lint && pnpm typecheck && pnpm test && pnpm build && pnpm publint",
    "publint": "publint packages/kstyled && publint packages/babel-plugin-kstyled",
    "release:check": "pnpm check && pnpm publish:dry",
    "publish:dry": "pnpm publish -r --filter '!example' --filter '!kstyled-docs' --access public --dry-run --no-git-checks",
    "publish:dry:beta": "pnpm publish -r --filter '!example' --filter '!kstyled-docs' --access public --tag beta --dry-run --no-git-checks",
    "version:beta": "node scripts/bump-version.js beta",
    "version:release": "node scripts/bump-version.js release",
    "version:patch": "node scripts/bump-version.js patch",
    "version:minor": "node scripts/bump-version.js minor",
    "version:major": "node scripts/bump-version.js major",
    "version:get": "node -p \"require('./packages/kstyled/package.json').version\""
  },
  "devDependencies": {
    "@turbo/gen": "^2.3.3",
    "@types/jest": "^29.5.14",
    "prettier": "^3.4.2",
    "publint": "^0.3.21",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@8.15.4"
}
