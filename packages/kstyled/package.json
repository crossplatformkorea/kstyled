{
  "name": "kstyled",
  "version": "0.4.1",
  "type": "commonjs",
  "description": "Compile-time CSS-in-JS for React Native with a small, predictable runtime",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "react-native": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean --minify --sourcemap",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx",
    "test": "jest --passWithNoTests",
    "prepublishOnly": "node ../../scripts/assert-ci-publish.js",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "keywords": [
    "react-native",
    "styled-components",
    "css-in-js",
    "expo",
    "stylesheet",
    "performance",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/crossplatformkorea/kstyled.git",
    "directory": "packages/kstyled"
  },
  "homepage": "https://crossplatformkorea.github.io/kstyled",
  "author": "hyodotdev (https://hyo.dev)",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "peerDependencies": {
    "react": ">=17.0.0",
    "react-native": ">=0.64.0"
  },
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@babel/preset-react": "^7.26.0",
    "@babel/preset-typescript": "^7.26.0",
    "@types/babel__core": "^7.20.5",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.1.10",
    "@types/react-native": "^0.73.0",
    "@typescript-eslint/eslint-plugin": "^8.19.1",
    "@typescript-eslint/parser": "^8.19.1",
    "eslint": "^9.18.0",
    "jest": "^29.7.0",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "ts-jest": "^29.2.5",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2"
  }
}
